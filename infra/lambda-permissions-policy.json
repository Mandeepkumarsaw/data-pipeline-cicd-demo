{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadCustomerCsvFromS3",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::data-pipeline-artifacts-667198667792",
        "arn:aws:s3:::data-pipeline-artifacts-667198667792/*"
      ]
    },
   {
      "Sid": "WriteRecordsToDynamoDb",
      "Effect": "Allow",
      "Action": [
        "dynamodb:PutItem",
        "dynamodb:BatchWriteItem",
        "dynamodb:DescribeTable"
      ],
      "Resource": "arn:aws:dynamodb:ap-southeast-2:667198667792:table/customer-data"
    },
    {
      "Sid": "LambdaBasicExecution",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:eu-north-1:667198667792:*"
    }
  ]
}
